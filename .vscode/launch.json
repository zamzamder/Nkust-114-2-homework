{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Launch (Project1.Web)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/Project1.Web/bin/Debug/net10.0/Project1.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/Project1.Web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Production"
      },
      "console": "internalConsole",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}
